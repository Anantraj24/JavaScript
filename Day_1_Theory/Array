CODING QUESTIONS

Find sum of array:

let arr = [1, 2, 3, 4];

let sum = 0;

for (let val of arr) {
  sum += val;
}

console.log(sum);

Find largest number:

let arr = [10, 50, 30];

let max = arr[0];

for (let val of arr) {
  if (val > max) {
    max = val;
  }
}

console.log(max);
